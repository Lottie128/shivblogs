# Supabase Credentials for ShivBlogs
# Copy this file to .env and replace BOTH values with your real Supabase keys,
# then restart the dev server. If you leave these placeholders the app runs in
# DEMO mode (localStorage) instead of talking to Supabase.
# The anon key is a long JWT that starts with "eyJ" (Project Settings → API).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-api-key-here
